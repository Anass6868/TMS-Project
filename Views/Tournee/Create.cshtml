@model TMS_Project.ViewModels.TourneeFormViewModel

@{
    ViewData["Title"] = "Créer une tournée";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Créer une nouvelle tournée</h3>
        </div>
        <div class="card-body">
            @*  *@
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="@Model.Tournee.DateTournee" class="form-label">Date de la Tournée</label>
                        <input asp-for="@Model.Tournee.DateTournee" class="form-control" type="datetime-local" />
                        <span asp-validation-for="@Model.Tournee.DateTournee" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="@Model.Tournee.TransporteurId" class="form-label">Transporteur</label>
                        <select asp-for="@Model.Tournee.TransporteurId" asp-items="@Model.Transporteurs" class="form-select">
                            <option value="">-- Sélectionner --</option>
                        </select>
                        <span asp-validation-for="@Model.Tournee.TransporteurId" class="text-danger"></span>
                    </div>

                    @* Statut *@
                    <div class="col-md-4">
                        <label asp-for="@Model.Tournee.StatutTournee" class="form-label">Statut</label>
                        <select asp-for="@Model.Tournee.StatutTournee" class="form-select">
                            <option value="Planifiée">Planifiée</option>
                            <option value="En cours">En cours</option>
                            <option value="Terminée">Terminée</option>
                        </select>
                    </div>

                    @* Camion *@
                    <div class="col-md-6">
                        <label asp-for="@Model.Tournee.CamionId" class="form-label">Camion</label>
                        <select asp-for="@Model.Tournee.CamionId" asp-items="@Model.Camions" class="form-select">
                            <option value="">-- Sélectionner --</option>
                        </select>
                        <span asp-validation-for="@Model.Tournee.CamionId" class="text-danger"></span>
                    </div>

                    @* Chauffeur *@
                    <div class="col-md-6">
                        <label asp-for="@Model.Tournee.ChauffeurId" class="form-label">Chauffeur</label>
                        <select asp-for="@Model.Tournee.ChauffeurId" asp-items="@Model.Chauffeurs" class="form-select">
                            <option value="">-- Sélectionner --</option>
                        </select>
                        <span asp-validation-for="@Model.Tournee.ChauffeurId" class="text-danger"></span>
                    </div>

                    @* Livraisons Disponibles *@
                    <div class="col-12">
                        <label class="form-label fw-bold">📦 Affecter des livraisons disponibles</label>
                        <div class="border rounded p-3 bg-light" style="max-height: 200px; overflow-y: auto;">
                            @if (Model.LivraisonsDisponibles == null || !Model.LivraisonsDisponibles.Any())
                            {
                                <div class="text-muted italic">Aucune livraison disponible.</div>
                            }
                            else
                            {
                                foreach (var livraison in Model.LivraisonsDisponibles)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="SelectedLivraisonIds"
                                               value="@livraison.LivraisonId"
                                               id="liv-@livraison.LivraisonId"
                                        @(Model.SelectedLivraisonIds != null && Model.SelectedLivraisonIds.Contains(livraison.LivraisonId) ? "checked" : "") />
                                        <label class="form-check-label" for="liv-@livraison.LivraisonId">
                                            #@livraison.LivraisonId - @livraison.Adresse (@livraison.PoidsKg kg)
                                        </label>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <hr />
                    <h5 class="text-primary">Coût Initial (MAD)</h5>

                    <div class="col-md-4">
                        <label asp-for="@Model.TypeCout" class="form-label">Type de coût</label>
                        <input asp-for="@Model.TypeCout" class="form-control" placeholder="Carburant, Péage..." />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="@Model.MontantCout" class="form-label">Montant</label>
                        <input asp-for="@Model.MontantCout" class="form-control" type="number" step="0.01" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="@Model.DescCout" class="form-label">Description</label>
                        <input asp-for="@Model.DescCout" class="form-control" />
                    </div>
                </div>

                <div class="mt-4 border-top pt-3">
                    <button type="submit" class="btn btn-success px-4">Enregistrer la tournée</button>
                    <a asp-action="Index" class="btn btn-secondary px-4">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}