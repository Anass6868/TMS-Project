@model DemandeLivraison

@{
    ViewData["Title"] = "Recu client";
    var recuDisponible = Model.Statut == "Acceptee" || Model.Statut == "Livree";
}

@if (!recuDisponible)
{
    <div class="section-card confirmation-card text-center">
        <div class="auth-icon mx-auto"><i class="bi bi-lock"></i></div>
        <h1 class="page-title mt-3">Recu non disponible</h1>
        <p class="page-lead">L'administrateur doit d'abord donner son accord sur la demande. Pour le moment, vous pouvez seulement suivre le statut.</p>
        <div class="mini-info-list text-start">
            <div class="mini-info-item"><span>Reference</span><span>#@Model.DemandeLivraisonId</span></div>
            <div class="mini-info-item"><span>Statut</span><span>@Model.Statut</span></div>
        </div>
        <a asp-action="Suivi" class="btn btn-soft mt-4">
            <i class="bi bi-search"></i> Suivre ma demande
        </a>
    </div>
}
else
{
    <div class="section-card">
        <div class="page-header">
            <div>
                <h1 class="page-title">Recu de validation</h1>
                <p class="page-lead">Ce reçu confirme que TRANS-LOG a accepte votre demande.</p>
            </div>
            <span class="status-chip @(Model.Statut == "Livree" ? "status-ok" : "status-wait")">
                @Model.Statut
            </span>
        </div>

        <div class="mini-info-list">
            <div class="mini-info-item"><span>Reference</span><span>#@Model.DemandeLivraisonId</span></div>
            <div class="mini-info-item"><span>Numero recu</span><span>@Model.NumeroRecu</span></div>
            <div class="mini-info-item"><span>Client</span><span>@Model.Client?.Nom</span></div>
            <div class="mini-info-item"><span>Email</span><span>@Model.Client?.Email</span></div>
            <div class="mini-info-item"><span>Telephone</span><span>@Model.Client?.Telephone</span></div>
            <div class="mini-info-item"><span>Service</span><span>@Model.TypeService</span></div>
            <div class="mini-info-item"><span>Marchandise</span><span>@Model.DescriptionMarchandise</span></div>
            <div class="mini-info-item"><span>Quantite</span><span>@Model.Quantite</span></div>
            <div class="mini-info-item"><span>Poids</span><span>@Model.PoidsKg kg</span></div>
            <div class="mini-info-item"><span>Adresse livraison</span><span>@Model.Adresse</span></div>
            <div class="mini-info-item"><span>Date souhaitee</span><span>@Model.DateSouhaitee.ToString("dd/MM/yyyy")</span></div>
            <div class="mini-info-item"><span>Date validation</span><span>@Model.DateValidation?.ToString("dd/MM/yyyy HH:mm")</span></div>
            <div class="mini-info-item"><span>Montant</span><span>@Model.MontantEstime.ToString("0.00") MAD</span></div>
        </div>
    </div>
}
