@model DemandeLivraison

@{
    ViewData["Title"] = "Demande envoyee";
}

<div class="section-card confirmation-card">
    <div class="auth-icon"><i class="bi bi-send-check"></i></div>
    <h1 class="page-title mt-3">Votre demande est en cours d'execution</h1>
    <p class="page-lead">Merci @Model.Client?.Nom. Votre demande a ete envoyee a l'administration TRANS-LOG pour validation.</p>

    @if (TempData["ClientNotification"] != null)
    {
        <div class="alert alert-success mt-4">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["ClientNotification"]
        </div>
    }

    <div class="mini-info-list">
        <div class="mini-info-item"><span>Reference de suivi</span><span>#@Model.DemandeLivraisonId</span></div>
        <div class="mini-info-item"><span>Email</span><span>@Model.Client?.Email</span></div>
        <div class="mini-info-item"><span>Service</span><span>@Model.TypeService</span></div>
        <div class="mini-info-item"><span>Statut</span><span>@Model.Statut</span></div>
    </div>

    <div class="alert alert-warning mt-4">
        <i class="bi bi-lock-fill me-2"></i>Le reçu sera disponible seulement apres l'accord de l'administrateur.
    </div>

    <div class="hero-actions mt-4">
        <a asp-action="Suivi" class="btn btn-soft">
            <i class="bi bi-search"></i> Suivre ma demande
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-soft">
            <i class="bi bi-house"></i> Retour accueil
        </a>
    </div>
</div>
