@{
    ViewData["Title"] = "Dashboard";
}

<section class="hero-card dashboard-hero">
    <span class="hero-eyebrow"><i class="bi bi-activity"></i> Pilotage temps reel</span>
    <h1 class="hero-title">Vue globale de vos operations transport</h1>
    <p class="hero-subtitle">Suivez la flotte active, les tournees et les demandes clients depuis un seul tableau de bord.</p>
    <div class="hero-actions">
        <a asp-controller="Livraison" asp-action="Create" class="btn btn-dashboard-primary">
            <i class="bi bi-plus-circle"></i> Nouvelle livraison
        </a>
        <a asp-controller="Tournee" asp-action="Create" class="btn btn-dashboard-secondary">
            <i class="bi bi-calendar-plus"></i> Planifier une tournee
        </a>
    </div>
</section>

<section class="dashboard-grid">
    <article class="stat-card grid-span-3">
        <div class="stat-icon"><i class="bi bi-buildings"></i></div>
        <div class="stat-label">Transporteurs</div>
        <div class="stat-value">@ViewBag.Transporteurs</div>
        <div class="stat-hint">Partenaires enregistres</div>
    </article>

    <article class="stat-card grid-span-3">
        <div class="stat-icon"><i class="bi bi-truck"></i></div>
        <div class="stat-label">Camions actifs</div>
        <div class="stat-value">@ViewBag.CamionsActifs</div>
        <div class="stat-hint">Disponibles dans la flotte</div>
    </article>

    <article class="stat-card grid-span-3">
        <div class="stat-icon"><i class="bi bi-person-vcard"></i></div>
        <div class="stat-label">Chauffeurs actifs</div>
        <div class="stat-value">@ViewBag.ChauffeursActifs</div>
        <div class="stat-hint">Equipes mobilisables</div>
    </article>

    <article class="stat-card grid-span-3">
        <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
        <div class="stat-label">Livraisons du jour</div>
        <div class="stat-value">@ViewBag.LivraisonsJour</div>
        <div class="stat-hint">A traiter aujourd'hui</div>
    </article>

    <article class="dashboard-card grid-span-8">
        <h2 class="section-title">Acces rapide</h2>
        <p class="section-subtitle">Naviguez directement vers les modules operationnels.</p>
        <div class="quick-links mt-3">
            <a asp-controller="Transporteur" asp-action="Index" class="quick-link">
                <i class="bi bi-buildings"></i>
                <span class="quick-link-title">Transporteurs</span>
                <span class="quick-link-text">Dossiers, contacts et flotte rattachee.</span>
            </a>
            <a asp-controller="Camion" asp-action="Index" class="quick-link">
                <i class="bi bi-truck"></i>
                <span class="quick-link-title">Camions</span>
                <span class="quick-link-text">Capacite, immatriculations et statut.</span>
            </a>
            <a asp-controller="Chauffeur" asp-action="Index" class="quick-link">
                <i class="bi bi-person-vcard"></i>
                <span class="quick-link-title">Chauffeurs</span>
                <span class="quick-link-text">Conducteurs actifs et permis.</span>
            </a>
            <a asp-controller="DemandeLivraison" asp-action="Admin" class="quick-link">
                <i class="bi bi-bell"></i>
                <span class="quick-link-title">Demandes clients</span>
                <span class="quick-link-text">Valider les nouvelles demandes.</span>
            </a>
        </div>
    </article>

    <article class="dashboard-card grid-span-4">
        <h2 class="section-title">Priorites</h2>
        <p class="section-subtitle">Points qui demandent une attention rapide.</p>
        <div class="mini-info-list">
            <div class="mini-info-item">
                <span><i class="bi bi-hourglass-split me-2"></i>Demandes en attente</span>
                <span>@ViewBag.DemandesEnAttente</span>
            </div>
            <div class="mini-info-item">
                <span><i class="bi bi-signpost-split me-2"></i>Tournees en cours</span>
                <span>@ViewBag.TourneesEnCours</span>
            </div>
        </div>
    </article>
</section>
