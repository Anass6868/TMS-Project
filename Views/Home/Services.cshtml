@{
    ViewData["Title"] = "Services";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Details de nos services</h1>
        <p class="page-lead">Choisissez le niveau de transport qui correspond a votre marchandise.</p>
    </div>
</div>

<section class="dashboard-grid">
    <article class="service-card grid-span-3">
        <i class="bi bi-box"></i>
        <h2>Standard</h2>
        <p>Livraison planifiee pour les colis et marchandises classiques.</p>
    </article>
    <article class="service-card grid-span-3">
        <i class="bi bi-lightning-charge"></i>
        <h2>Express</h2>
        <p>Traitement prioritaire pour les demandes urgentes.</p>
    </article>
    <article class="service-card grid-span-3">
        <i class="bi bi-gem"></i>
        <h2>Fragile</h2>
        <p>Manipulation attentive pour objets sensibles ou cassables.</p>
    </article>
    <article class="service-card grid-span-3">
        <i class="bi bi-thermometer-snow"></i>
        <h2>Refrigere</h2>
        <p>Transport adapte aux produits qui exigent une temperature controlee.</p>
    </article>
</section>
