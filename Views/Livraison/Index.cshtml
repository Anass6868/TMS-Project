@model IEnumerable<TMS_Project.Models.Livraison>

@{
    ViewData["Title"] = "Liste des Livraisons";
}

<!-- CSS dial SweetAlert2 -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam"></i> Liste des Livraisons</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle"></i> Nouvelle Livraison
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3">ID</th>
                    <th>Client</th>
                    <th>Adresse</th>
                    <th>Poids (kg)</th>
                    <th>Date prévue</th>
                    <th>Statut</th>
                    <th>Tournée</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    @* *@
                    <tr>
                        <td colspan="8" class="text-center py-5 bg-light">
                            <div class="py-4">
                                <i class="bi bi-box2 fs-1 text-muted opacity-50 d-block mb-3"></i>
                                <p class="text-muted mb-0">Aucune livraison enregistrée.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var l in Model)
                    {
                        var cls = l.StatutLivraison switch
                        {
                            "Livrée" => "bg-success",
                            "En cours" => "bg-warning text-dark",
                            "Échouée" => "bg-danger",
                            _ => "bg-secondary"
                        };
                        <tr>
                            <td class="ps-3"><strong>#@l.LivraisonId</strong></td>
                            <td>@l.Client?.Nom</td>
                            <td>@l.Adresse</td>
                            <td>@l.PoidsKg</td>
                            <td>@l.DateLivraison.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge @cls">@l.StatutLivraison</span></td>
                            <td>
                                @if (l.Tournee != null)
                                {
                                    <span class="badge bg-info text-dark">Tournée #@l.TourneeId</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted border">Non affectée</span>
                                }
                            </td>
                            <td class="text-center pe-3">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Details" asp-route-id="@l.LivraisonId" class="btn btn-sm btn-outline-info rounded-pill"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@l.LivraisonId" class="btn btn-sm btn-outline-warning rounded-pill"><i class="bi bi-pencil"></i></a>
                                    
                                    <form id="delete-form-@l.LivraisonId" asp-action="Delete" asp-route-id="@l.LivraisonId" method="post" style="display:none;">
                                        @Html.AntiForgeryToken()
                                    </form>

                                    <button type="button" class="btn btn-sm btn-outline-danger rounded-pill" onclick="confirmDelete(@l.LivraisonId)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id) {
        Swal.fire({
        title: 'Supprimer la livraison ?',
        text: "Voulez-vous vraiment supprimer la livraison #" + id + " ?",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Oui, supprimer',
        cancelButtonText: 'Annuler',
        borderRadius: '15px'
        }).then((result) => {
        if (result.isConfirmed) {
        document.getElementById('delete-form-' + id).submit();
        }
        })
        }
    </script>
}