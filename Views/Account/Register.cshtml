@model TMS_Project.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Inscription";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-icon"><i class="bi bi-person-plus"></i></div>
        <h1 class="auth-title">Creer un compte</h1>
        <p class="auth-subtitle">Les nouveaux comptes recoivent le role User pour la consultation.</p>

        <form asp-action="Register" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    <input asp-for="Email" class="form-control" autocomplete="username" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-key"></i></span>
                    <input asp-for="Password" class="form-control" autocomplete="new-password" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label">Confirmation</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-check2-circle"></i></span>
                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-dashboard-primary auth-submit">
                <i class="bi bi-person-check"></i> Creer le compte
            </button>
        </form>

        <div class="auth-switch">
            Deja inscrit ?
            <a asp-action="Login">Se connecter</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
