@model Microsoft.AspNetCore.Identity.IdentityUser
@{
    ViewData["Title"] = "Mon Compte";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 p-4 bg-white">
                
                <div class="text-center mb-4">
                    <div class="display-4 text-success mb-2">
                        <i class="bi bi-person-badge-fill"></i>
                    </div>
                    <h2 class="fw-bold text-dark">Mon Espace Client</h2>
                    <p class="text-muted small">Gérez vos informations de connexion TRANS-LOG</p>
                </div>
                
                <hr class="text-muted opacity-25">
                
                <div class="card-body p-2">
                    
                    <div class="mb-4">
                        <label class="form-label text-secondary small fw-bold text-uppercase tracking-wider">
                            <i class="bi bi-person"></i> Nom d'utilisateur
                        </label>
                        <div class="form-control bg-light border-0 py-2.5 rounded-3 fw-medium text-dark">
                            @Model.UserName
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label text-secondary small fw-bold text-uppercase tracking-wider">
                            <i class="bi bi-envelope"></i> Adresse Email
                        </label>
                        <div class="form-control bg-light border-0 py-2.5 rounded-3 fw-medium text-dark">
                            @Model.Email
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold text-uppercase tracking-wider">
                            <i class="bi bi-shield-check"></i> Statut du compte
                        </label>
                        <div>
                            <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-semibold">
                                <i class="bi bi-check-circle-fill"></i> Client Vérifié
                            </span>
                        </div>
                    </div>

                </div>
                
                <hr class="text-muted opacity-25 my-4">
                
                <div class="d-grid gap-2">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill py-2 fw-medium">
                        <i class="bi bi-arrow-left"></i> Retour à l'accueil
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>