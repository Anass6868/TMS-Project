@model TMS_Project.Models.Transporteur

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0"><i class="bi bi-info-circle me-2"></i>Détails du Transporteur</h4>
        </div>
        <div class="card-body p-4">
            <div class="row mb-4">
                <div class="col-md-4 text-muted small fw-bold">ID</div>
                <div class="col-md-8 fw-bold">#@Model.TransporteurId</div>
            </div>

            <div class="row mb-4">
                <div class="col-md-4 text-muted small fw-bold">NOM</div>
                <div class="col-md-8 h5 fw-bold text-dark">@Model.Nom</div>
            </div>

            <div class="row mb-4">
                <div class="col-md-4 text-muted small fw-bold">COORDONNÉES</div>
                <div class="col-md-8">
                    <p class="mb-1"><i class="bi bi-geo-alt me-2 text-primary"></i>@Model.Adresse</p>
                    <p class="mb-1"><i class="bi bi-telephone me-2 text-primary"></i>@Model.Telephone</p>
                    <p class="mb-1"><i class="bi bi-envelope me-2 text-primary"></i>@Model.Email</p>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-4 text-muted small fw-bold">DATE D'INTÉGRATION</div>
                <div class="col-md-8 text-muted">
                    @Model.DateCreation.ToString("dd/MM/yyyy")
                </div>
            </div>

            <hr class="my-4 opacity-25">

            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.TransporteurId" class="btn btn-warning rounded-pill px-4 fw-bold">
                    <i class="bi bi-pencil"></i> Modifier
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                    Retour à la liste
                </a>
            </div>
        </div>
    </div>
</div>