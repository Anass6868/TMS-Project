@model IEnumerable<TMS_Project.Models.Transporteur>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold">Transporteurs</h1>
        <p class="text-muted">Gère ton réseau de partenaires et accède rapidement à leurs dossiers.</p>
    </div>
    <a asp-action="Create" class="btn btn-outline-primary rounded-pill px-4 shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Créer un transporteur
    </a>
</div>

<div class="card shadow-sm border-0 rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="bg-light border-bottom">
                <tr>
                    <th class="ps-4 py-3 text-muted small fw-bold">ID</th>
                    <th class="py-3 text-muted small fw-bold">NOM DU TRANSPORTEUR</th>
                    <th class="py-3 text-muted small fw-bold">DATE D'AJOUT</th>
                    <th class="text-center py-3 text-muted small fw-bold">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <span class="badge bg-light text-success rounded-pill px-3 py-2 border">#@item.TransporteurId</span>
                        </td>
                        <td>
                            <div class="fw-bold text-dark">@item.Nom</div>
                        </td>
                        <td>
                            <div class="text-muted small">
                                <i class="bi bi-calendar3 me-1"></i> @item.DateCreation.ToString("dd/MM/yyyy")
                            </div>
                        </td>
                        <td class="text-center pe-4">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="Details" asp-route-id="@item.TransporteurId" class="btn btn-sm btn-light border rounded-pill px-3 shadow-sm text-dark" title="Détails">
                                    <i class="bi bi-eye"></i> Détails
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.TransporteurId" class="btn btn-sm btn-outline-warning rounded-pill px-3 shadow-sm" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <form id="delete-form-@item.TransporteurId" asp-action="Delete" asp-route-id="@item.TransporteurId" method="post" style="display:none;">
                                    @Html.AntiForgeryToken()
                                </form>

                                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm"
                                        onclick="confirmDelete(@item.TransporteurId, '@item.Nom')" title="Supprimer">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id, name) {
        Swal.fire({
        title: 'Supprimer ?',
        text: "Voulez-vous supprimer le transporteur " + name + " ?",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Oui, supprimer',
        cancelButtonText: 'Annuler'
        }).then((result) => {
        if (result.isConfirmed) {
        var form = document.getElementById('delete-form-' + id);
        if (form) form.submit();
        }
        });
        }

        @if (TempData["Success"] != null)
        {
            <text>
                Swal.fire({ icon: 'success', title: 'Succès', text: '@Html.Raw(TempData["Success"])', timer: 2500, showConfirmButton: false });
            </text>
        }

        @if (TempData["Error"] != null)
        {
            <text>
                Swal.fire({ icon: 'error', title: 'Erreur', text: '@Html.Raw(TempData["Error"])', confirmButtonColor: '#0d6efd' });
            </text>
        }
    </script>
}