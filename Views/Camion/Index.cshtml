@model IEnumerable<TMS_Project.Models.Camion>

@{
    ViewData["Title"] = "Camions";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold">Camions</h1>
        <p class="text-muted">Gestion de la flotte et suivi des immatriculations.</p>
    </div>
    <a asp-action="Create" class="btn btn-outline-primary rounded-pill px-4 shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Créer un camion
    </a>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="bg-light border-bottom">
                <tr>
                    <th class="ps-4 py-3 text-muted small fw-bold">ID</th>
                    <th class="py-3 text-muted small fw-bold">IMMATRICULATION</th>
                    <th class="py-3 text-muted small fw-bold">MODÈLE</th>
                    <th class="py-3 text-muted small fw-bold">TRANSPORTEUR</th>
                    <th class="text-center py-3 text-muted small fw-bold">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <span class="badge bg-light text-success rounded-pill px-3 py-2 border">#@item.CamionId</span>
                        </td>
                        <td class="fw-bold text-dark">@item.Immatriculation</td>
                        <td>@item.Modele</td>
                        <td>
                            <span class="text-muted">@(item.Transporteur?.Nom ?? "N/A")</span>
                        </td>
                        <td class="text-center pe-4">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="Details" asp-route-id="@item.CamionId" class="btn btn-sm btn-light border rounded-pill px-3 shadow-sm text-dark">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.CamionId" class="btn btn-sm btn-outline-warning rounded-pill px-3 shadow-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <form id="delete-form-@item.CamionId" asp-action="Delete" asp-route-id="@item.CamionId" method="post" style="display:none;">
                                    @Html.AntiForgeryToken()
                                </form>

                                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm"
                                        onclick="confirmDelete(@item.CamionId, '@item.Immatriculation')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id, immat) {
        Swal.fire({
        title: 'Supprimer ?',
        text: "Voulez-vous supprimer le camion " + immat + " ?",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Oui, supprimer',
        cancelButtonText: 'Annuler'
        }).then((result) => {
        if (result.isConfirmed) {
        var form = document.getElementById('delete-form-' + id);
        if (form) form.submit();
        }
        });
        }


        @if (TempData["Success"] != null)
        {
            <text>
                Swal.fire({
                icon: 'success',
                title: 'Succès',
                text: '@Html.Raw(TempData["Success"])',
                timer: 2500,
                showConfirmButton: false
                });
            </text>
        }


        @if (TempData["Error"] != null)
        {
            <text>
                Swal.fire({
                icon: 'error',
                title: 'Opération impossible',
                text: '@Html.Raw(TempData["Error"])',
                confirmButtonColor: '#0d6efd'
                });
            </text>
        }
    </script>
}